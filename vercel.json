  "config": {
    "forge": {
      "packagerConfig": {
        "name": "PioneerOS",
        "executableName": "PioneerOS"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "PioneerOS",
            "authors": "Pioneer",
            "description": "Sovereign AI OS",
            "noMsi": true,
            "setupExe": "PioneerOS-Setup.exe"
          }
